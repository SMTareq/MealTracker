{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Launch (MealExpenseTracker.Api)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/bin/Debug/net8.0/MealExpenseTracker.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5118;https://localhost:7118"
      },
      "justMyCode": false
    }
  ]
}
